# Streamlit Cloud 배포 시 Settings > Secrets에 아래 내용을 입력하세요
# 또는 이 파일을 secrets.toml로 복사하여 로컬에서 사용

SEMRUSH_API_KEY = "your_api_key"
SEMRUSH_PROJECT_ID = "your_project_id"
SEMRUSH_CAMPAIGN_ID = "your_campaign_id"
SEMRUSH_LISTING_TOKEN = "your_oauth_token"
GCP_PROJECT_ID = "your_gcp_project"
BQ_DATASET = "semrush_data"
SEMRUSH_DATABASE = "us"
TARGET_DOMAIN = "example.com"
