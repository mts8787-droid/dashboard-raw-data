# SEMrush API
SEMRUSH_API_KEY=your_semrush_api_key_here

# SEMrush Enterprise - Project/Campaign
SEMRUSH_PROJECT_ID=your_project_id
SEMRUSH_CAMPAIGN_ID=your_project_id_campaign_id

# SEMrush Listing Management (OAuth Bearer Token)
SEMRUSH_LISTING_TOKEN=your_oauth_bearer_token

# Google Cloud / BigQuery
GCP_PROJECT_ID=your_gcp_project_id
BQ_DATASET=semrush_data
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json

# SEMrush 설정
SEMRUSH_DATABASE=us
TARGET_DOMAIN=example.com
